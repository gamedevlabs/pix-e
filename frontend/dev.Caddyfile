socvm2.cit.tum.de {
    encode gzip

    handle /api/* {
        reverse_proxy django:8000
    }

    handle /static/* {
        root * /app/staticfiles
        file_server
    }

    handle {
        root * /usr/share/caddy/html
        try_files {path} {path}/ /index.html
        file_server
    }
}
